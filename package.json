{
  "name": "moltpay",
  "version": "0.1.0",
  "description": "Solana payment SDK for AI agents - supports OpenClaw, LangChain, CrewAI, and MCP",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "moltpay-mcp": "./dist/bin/mcp-server.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/charlie-818/moltpay.git"
  },
  "homepage": "https://github.com/charlie-818/moltpay#readme",
  "bugs": {
    "url": "https://github.com/charlie-818/moltpay/issues"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "build:ui": "BUILD_LIB=true vite build",
    "build:site": "vite build",
    "build:all": "npm run build && npm run build:site",
    "dev:ui": "vite",
    "preview": "vite preview",
    "start": "npx serve dist/public -l $PORT",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/**/*.ts",
    "dev": "ts-node src/index.ts",
    "mcp:stdio": "ts-node src/bin/mcp-server.ts",
    "mcp:dev": "MOLTPAY_ENCRYPTION_KEY=test-dev-key ts-node src/bin/mcp-server.ts"
  },
  "keywords": [
    "solana",
    "payments",
    "ai-agents",
    "openclaw",
    "langchain",
    "crewai",
    "cryptocurrency",
    "web3",
    "skills",
    "mcp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@solana/web3.js": "^1.95.0",
    "@solana/spl-token": "^0.4.0",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "@radix-ui/react-alert-dialog": "^1.0.5",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.0.6",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@radix-ui/react-slot": "^1.0.2",
    "better-sqlite3": "^9.4.3",
    "bip39": "^3.1.0",
    "bs58": "^5.0.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "ed25519-hd-key": "^1.3.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.312.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tailwind-merge": "^2.2.1",
    "tweetnacl": "^1.0.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "supertest": "^6.3.4",
    "vitest": "^1.2.2",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.17",
    "jest": "^29.7.0",
    "postcss": "^8.4.33",
    "tailwindcss": "^3.4.1",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vite": "^5.0.12"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
